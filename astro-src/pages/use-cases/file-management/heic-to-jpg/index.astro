---
import Layout from '../../../../layouts/Layout.astro';
import PostHogInit from '../../../../../src/components/PostHogInit';
import Navigation from '../../../../components/Navigation.astro';
import HJHeroSection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJHeroSection';
import HJProblemSection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJProblemSection';
import HJSolutionSection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJSolutionSection';
import HJComparisonSection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJComparisonSection';
import HJPersonasSection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJPersonasSection';
import HJFinalCTASection from '../../../../../src/components/use-cases/file-management/heic-to-jpg/HJFinalCTASection';
import WaitlistSection from '../../../../../src/components/use-cases/WaitlistSection';
import Footer from '../../../../../src/components/Footer';
import MoreConversions from '../../../../components/MoreConversions.astro';
---

<Layout 
  title="Batch Convert HEIC to JPG Locally | Mac & Windows | Desktop Commander"
  description="Batch convert HEIC to JPG locally on Mac and Windows — no uploads, no cloud, no file limits. Point Desktop Commander at a folder and get JPGs in seconds. Free forever."
>
  <PostHogInit client:load />
  
  <div class="min-h-screen bg-background">
    <Navigation />
    
    <main>
      <HJHeroSection client:load />
      <HJProblemSection client:visible />
      <HJSolutionSection client:visible />
      <HJComparisonSection client:visible />
      <WaitlistSection useCase="heic_to_jpg" client:visible />
      <HJPersonasSection client:visible />
      <HJFinalCTASection client:visible />
    </main>
    
    <MoreConversions current="heic-to-jpg" />
      <Footer client:visible />
  </div>
</Layout>

<style is:global>
  @import '../../../../../src/index.css';
</style>
