---
import Layout from '../../../layouts/Layout.astro';
import PostHogInit from '../../../../src/components/PostHogInit';
import Navigation from '../../../components/Navigation.astro';
import KnowledgeManagementHero from '../../../../src/components/use-cases/knowledge-management/KnowledgeManagementHero';
import KMProblemSection from '../../../../src/components/use-cases/knowledge-management/KMProblemSection';
import KMSolutionSection from '../../../../src/components/use-cases/knowledge-management/KMSolutionSection';
import KMWhyDifferentSection from '../../../../src/components/use-cases/knowledge-management/KMWhyDifferentSection';
import KMToolsSection from '../../../../src/components/use-cases/knowledge-management/KMToolsSection';
import KMWhyMarkdownSection from '../../../../src/components/use-cases/knowledge-management/KMWhyMarkdownSection';
import KMGitNativeSection from '../../../../src/components/use-cases/knowledge-management/KMGitNativeSection';
import KMPersonasSection from '../../../../src/components/use-cases/knowledge-management/KMPersonasSection';
import WaitlistSection from '../../../../src/components/use-cases/WaitlistSection';
import KMFinalCTASection from '../../../../src/components/use-cases/knowledge-management/KMFinalCTASection';
import Footer from '../../../../src/components/Footer';
---

<Layout 
  title="Chat With Your Notes — AI Knowledge Base for Markdown & Local Files | Desktop Commander"
  description="Turn your markdown notes, docs, and local files into an AI-searchable knowledge base. Write, edit, and link notes in natural language — all on your own machine."
>
  <PostHogInit client:load />
  
  <div class="min-h-screen bg-background">
    <Navigation />
    
    <main>
      <KnowledgeManagementHero client:load />
      <KMProblemSection client:visible />
      <KMSolutionSection client:visible />
      <KMWhyDifferentSection client:visible />
      <KMWhyMarkdownSection client:visible />
      <KMToolsSection client:visible />
      <KMGitNativeSection client:visible />
      <KMPersonasSection client:visible />
      <WaitlistSection useCase="knowledge_management" client:visible />
      <KMFinalCTASection client:visible />
    </main>
    
    <Footer client:visible />
  </div>
</Layout>

<style is:global>
  @import '../../../../src/index.css';
</style>
