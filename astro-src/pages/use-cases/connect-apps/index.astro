---
import Layout from '../../../layouts/Layout.astro';
import PostHogInit from '../../../../src/components/PostHogInit';
import Navigation from '../../../components/Navigation.astro';
import CAHeroSection from '../../../../src/components/use-cases/connect-apps/CAHeroSection';
import CAProblemSection from '../../../../src/components/use-cases/connect-apps/CAProblemSection';
import CASolutionSection from '../../../../src/components/use-cases/connect-apps/CASolutionSection';
import CAWorkflowChainsSection from '../../../../src/components/use-cases/connect-apps/CAWorkflowChainsSection';
import CAExamplesSection from '../../../../src/components/use-cases/connect-apps/CAExamplesSection';
import CAComparisonSection from '../../../../src/components/use-cases/connect-apps/CAComparisonSection';
import CAHowItWorksSection from '../../../../src/components/use-cases/connect-apps/CAHowItWorksSection';
import CAPersonasSection from '../../../../src/components/use-cases/connect-apps/CAPersonasSection';
import CAFinalCTASection from '../../../../src/components/use-cases/connect-apps/CAFinalCTASection';
import Footer from '../../../../src/components/Footer';
---

<Layout 
  title="Connect Your Apps With AI — Workflow Automation for HubSpot, WordPress & 100+ Tools | Desktop Commander"
  description="Skip the clicks. Describe what you want and Desktop Commander talks to HubSpot, WordPress, Google Analytics and 100+ other tools through MCP."
>
  <PostHogInit client:load />
  
  <div class="min-h-screen bg-background">
    <Navigation />
    
    <main>
      <CAHeroSection client:load />
      <CAProblemSection client:visible />
      <CASolutionSection client:visible />
      <CAWorkflowChainsSection client:visible />
      <CAExamplesSection client:visible />
      <CAComparisonSection client:visible />
      <CAHowItWorksSection client:visible />
      <CAPersonasSection client:visible />
      <CAFinalCTASection client:visible />
    </main>
    
    <Footer client:visible />
  </div>
</Layout>

<style is:global>
  @import '../../../../src/index.css';
</style>
