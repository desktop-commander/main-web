---
import Layout from '../../../layouts/Layout.astro';
import PostHogInit from '../../../../src/components/PostHogInit';
import Navigation from '../../../components/Navigation.astro';
import BPHeroSection from '../../../../src/components/use-cases/build-prototype/BPHeroSection';
import BPProblemSection from '../../../../src/components/use-cases/build-prototype/BPProblemSection';
import BPSolutionSection from '../../../../src/components/use-cases/build-prototype/BPSolutionSection';
import BPExamplesSection from '../../../../src/components/use-cases/build-prototype/BPExamplesSection';
import BPWhyDifferentSection from '../../../../src/components/use-cases/build-prototype/BPWhyDifferentSection';
import BPComparisonSection from '../../../../src/components/use-cases/build-prototype/BPComparisonSection';
import BPCloudComparisonSection from '../../../../src/components/use-cases/build-prototype/BPCloudComparisonSection';
import WaitlistSection from '../../../../src/components/use-cases/WaitlistSection';
import BPPersonasSection from '../../../../src/components/use-cases/build-prototype/BPPersonasSection';
import BPFinalCTASection from '../../../../src/components/use-cases/build-prototype/BPFinalCTASection';
import Footer from '../../../../src/components/Footer';
---

<Layout 
  title="Vibe-Code Your Next App — AI App Builder on Your Desktop | Desktop Commander"
  description="Describe what you want and get working code on your own machine. Python, JavaScript, HTML/CSS, Git, Terminal — no cloud IDE, no setup, no learning to code."
>
  <PostHogInit client:load />
  
  <div class="min-h-screen bg-background">
    <Navigation />
    
    <main>
      <BPHeroSection client:load />
      <BPProblemSection client:visible />
      <BPSolutionSection client:visible />
      <BPExamplesSection client:visible />
      <BPWhyDifferentSection client:visible />
      <BPCloudComparisonSection client:visible />
      <BPComparisonSection client:visible />
      <WaitlistSection useCase="build_prototype" client:visible />
      <BPPersonasSection client:visible />
      <BPFinalCTASection client:visible />
    </main>
    
    <Footer client:visible />
  </div>
</Layout>

<style is:global>
  @import '../../../../src/index.css';
</style>
