---
import Layout from '../../../layouts/Layout.astro';
import PostHogInit from '../../../../src/components/PostHogInit';
import Navigation from '../../../components/Navigation.astro';
import Footer from '../../../../src/components/Footer';
import PromptDetailPage from '../../../../src/components/library/PromptDetailPage';
import { useCasesWithSlugs } from '../../../../src/data/library/useCases';

// Generate static paths for all prompts
export async function getStaticPaths() {
  return useCasesWithSlugs.map(useCase => ({
    params: { slug: useCase.slug },
    props: { useCase }
  }));
}

// Get the slug and useCase from Astro
const { slug } = Astro.params;
const { useCase } = Astro.props;

// If no use case found, redirect to main prompts page
if (!useCase) {
  return Astro.redirect('/library/prompts', 302);
}

const promptId = useCase.id;

// SEO #8 Tier 2: low-traffic prompts marked noindex to save crawl budget
// (also listed in robots.txt Disallow + hub card renders non-anchor so
// crawlers don't discover the URL in the first place).
const robotsMeta = useCase.noindex
  ? 'noindex, nofollow, noai, noimageai'
  : 'index, follow, noai, noimageai';
const googlebotMeta = useCase.noindex
  ? 'noindex, nofollow, noai'
  : 'index, follow, noai';
---

<Layout
  title={useCase.seoTitle || `${useCase.title} - Desktop Commander`}
  description={useCase.description}
  robots={robotsMeta}
  googlebot={googlebotMeta}
>
  <!-- Load PostHog early to initialize analytics -->
  <PostHogInit client:load />
  
  <div class="min-h-screen bg-background">
    <Navigation />
    <PromptDetailPage client:load useCase={useCase} />
    <Footer client:visible />
  </div>
</Layout>

<style is:global>
  @import '../../../../src/index.css';
</style>
