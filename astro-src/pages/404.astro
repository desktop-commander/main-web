---
import Layout from '../layouts/Layout.astro';
import PostHogInit from '../../src/components/PostHogInit';
import Navigation from '../components/Navigation.astro';
import Footer from '../../src/components/Footer';
---

<Layout
  title="Page not found | Desktop Commander"
  description="This page doesn't exist. Browse our top resources or head back home."
  robots="noindex, follow, noai, noimageai"
  googlebot="noindex, follow, noai"
>
  <PostHogInit client:load />

  <div class="min-h-screen bg-background flex flex-col">
    <Navigation />

    <main class="flex-1 pt-32 pb-16 md:pt-40 md:pb-24">
      <div class="container mx-auto max-w-3xl px-4 sm:px-6">

        <!-- 404 banner -->
        <div class="text-center mb-10">
          <div class="inline-flex items-center justify-center px-4 py-1.5 rounded-full bg-primary/10 border border-primary/30 mb-6">
            <span class="text-sm font-medium text-primary tracking-wide uppercase">404 — Not found</span>
          </div>

          <h1 class="text-4xl sm:text-5xl font-bold text-foreground mb-4">
            This page doesn't exist
          </h1>
          <p class="text-lg text-muted-foreground max-w-xl mx-auto">
            The link may be outdated, or the page may have moved. Here's where most people end up:
          </p>
        </div>

        <!-- Helpful destinations -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mb-10">
          <a
            href="/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="home"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
                <polyline points="9 22 9 12 15 12 15 22"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">Home</div>
              <div class="text-sm text-muted-foreground">What Desktop Commander is and how to get it.</div>
            </div>
          </a>

          <a
            href="/mcp/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="mcp"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="4 17 10 11 4 5"/>
                <line x1="12" y1="19" x2="20" y2="19"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">MCP server</div>
              <div class="text-sm text-muted-foreground">Install the Desktop Commander MCP for Claude Desktop and other hosts.</div>
            </div>
          </a>

          <a
            href="/use-cases/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="use-cases"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="7" rx="1"/>
                <rect x="14" y="3" width="7" height="7" rx="1"/>
                <rect x="3" y="14" width="7" height="7" rx="1"/>
                <rect x="14" y="14" width="7" height="7" rx="1"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">Use cases</div>
              <div class="text-sm text-muted-foreground">Analyze data, manage files, vibe-code apps, connect tools.</div>
            </div>
          </a>

          <a
            href="/library/prompts/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="library"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">Prompt library</div>
              <div class="text-sm text-muted-foreground">Copy-paste prompts for common Desktop Commander workflows.</div>
            </div>
          </a>

          <a
            href="/pricing/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="pricing"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="1" x2="12" y2="23"/>
                <path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">Pricing</div>
              <div class="text-sm text-muted-foreground">Free MCP, plus the App plans and what's included.</div>
            </div>
          </a>

          <a
            href="/blog/"
            class="group flex items-start gap-4 bg-dc-card/30 hover:bg-dc-card/60 border border-dc-border hover:border-primary/40 rounded-xl p-5 transition-colors"
            data-404-link="blog"
          >
            <div class="shrink-0 w-10 h-10 bg-primary/15 rounded-lg flex items-center justify-center text-primary">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
                <path d="M4 4.5A2.5 2.5 0 0 1 6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5z"/>
                <line x1="8" y1="7" x2="16" y2="7"/>
                <line x1="8" y1="11" x2="16" y2="11"/>
                <line x1="8" y1="15" x2="13" y2="15"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-foreground mb-1">Blog</div>
              <div class="text-sm text-muted-foreground">Guides, updates, and deep dives on MCP-driven workflows.</div>
            </div>
          </a>
        </div>

        <!-- Follow-up note -->
        <p class="text-center text-sm text-muted-foreground">
          If you followed a broken link, let us know at
          <a href="mailto:team@desktopcommander.app" class="text-primary hover:text-primary/80 underline">team@desktopcommander.app</a>.
        </p>

      </div>
    </main>

    <Footer client:visible />
  </div>

  <script is:inline>
    // Send a 404 event to PostHog once the page is live so we can track which
    // URLs are producing 404s and from which referrer.
    window.addEventListener('DOMContentLoaded', function () {
      if (window.posthog) {
        try {
          window.posthog.capture('404_page_viewed', {
            requested_url: window.location.href,
            requested_path: window.location.pathname,
            referrer: document.referrer || null,
          });
        } catch (err) {
          /* best-effort — don't break the page if capture fails */
        }
      }
    });

    // Track clicks on the destination cards so we know where 404 visitors go.
    document.querySelectorAll('[data-404-link]').forEach(function (el) {
      el.addEventListener('click', function () {
        if (window.posthog) {
          try {
            window.posthog.capture('404_destination_clicked', {
              destination: el.dataset['404Link'],
              from_url: window.location.href,
            });
          } catch (err) { /* noop */ }
        }
      });
    });
  </script>
</Layout>
