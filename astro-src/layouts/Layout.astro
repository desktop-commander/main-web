---
interface Props {
  title: string;
  description: string;
  ogImage?: string;
  robots?: string;
  googlebot?: string;
  /**
   * Override the `<link rel="canonical">` for this page.
   * Pass an absolute URL (e.g. "https://desktopcommander.app/library/prompts/")
   * when a page should point canonical signals at a different URL (e.g. a
   * duplicate/legacy page consolidating into the canonical hub).
   * Defaults to the current page's URL built from `Astro.site + Astro.url.pathname`.
   */
  canonical?: string;
  /**
   * schema.org JSON-LD payload(s) to emit in <head>.
   * Pass a single object for one graph node, or an array for multiple.
   * Each entry is serialized to its own <script type="application/ld+json"> tag.
   */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description,
  ogImage = '/bg-social-share.png',
  robots = 'index, follow, noai, noimageai',
  googlebot = 'index, follow, noai',
  canonical,
  jsonLd
} = Astro.props;

// Normalize jsonLd to an array so the template has a single code path.
const jsonLdNodes = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
const canonicalURL = canonical
  ? canonical
  : new URL(Astro.url.pathname, Astro.site || 'http://localhost:4321');
const siteBase = Astro.site?.origin || 'https://desktopcommander.app';
const absoluteOgImage = ogImage.startsWith('http') ? ogImage : `${siteBase}${ogImage}`;

// Import the base path fixer
import BasePathFixer from '../components/BasePathFixer.astro';

// Import global styles
import '../../src/index.css';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content="Desktop Commander" />
    
    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonicalURL} />
    
    <!-- Open Graph -->
    <meta property="og:site_name" content="Desktop Commander" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={absoluteOgImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@desktop_commander" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />
    
    <!-- Search and AI crawler directives -->
    <meta name="robots" content={robots} />
    <meta name="googlebot" content={googlebot} />

    {/* schema.org JSON-LD — one <script> per node so graphs stay separate & debuggable */}
    {jsonLdNodes.map((node) => (
      <script type="application/ld+json" set:html={JSON.stringify(node)} />
    ))}
    
    <!-- Cookiebot - MUST be first script in head -->
    <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="83cceb09-32d2-409b-ada6-17cc28478ba6" data-blockingmode="auto" type="text/javascript" async></script>
    
    <!-- Google tag (gtag.js) - blocked until statistics consent -->
    <script type="text/plain" data-cookieconsent="statistics" async src="https://www.googletagmanager.com/gtag/js?id=G-HXL4Y3Y62N"></script>
    <script type="text/plain" data-cookieconsent="statistics">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HXL4Y3Y62N');
    </script>
    
    <!-- Ahrefs Analytics - blocked until statistics consent -->
    <script type="text/plain" data-cookieconsent="statistics" src="https://analytics.ahrefs.com/analytics.js" data-key="5Iumy4Rr7Do+R0CWUtQkHA" async></script>
    
    <!-- Inject base path for React components -->
    <script is:inline define:vars={{ basePath: import.meta.env.BASE_URL }}>
      window.__BASE_PATH__ = basePath;
    </script>
    
    <!-- PostHog Analytics -->
    <!-- PostHog is initialized by the PostHogInit React component -->
    <!-- This ensures proper initialization in the Astro environment -->
  </head>
  <body>
    <BasePathFixer />
    <slot />
  </body>
</html>
